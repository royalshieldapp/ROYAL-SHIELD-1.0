# ─── Server ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Scanner (VirusTotal) ─────────────────────────────────────────────
VIRUSTOTAL_API_KEY=your_virustotal_key_here
VT_API_KEY=

# ─── AI Assistant (Gemini) ────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=

# ─── SOS / SMS (Twilio) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_FROM=
TWILIO_MESSAGING_SERVICE_SID=

# ─── Phone Lookup ─────────────────────────────────────────────────────
DID_API_KEY=your_did_api_key_here
NUMVERIFY_API_KEY=your_numverify_api_key_here

# ─── Billing (Google Play) ───────────────────────────────────────────
# Paste the full JSON content of your Google Play service account
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# ─── VPN (WireGuard) ─────────────────────────────────────────────────
VPN_PROVIDER=
VPN_SERVER_PUBLIC_KEY=
VPN_PORT=51820
VPN_DNS=1.1.1.1, 1.0.0.1
# Format: id:name:host,id:name:host
VPN_SERVERS=
VPN_ALLOW_STATIC_CONFIG=false

# ─── OpenClaw ─────────────────────────────────────────────────────────
OPENCLAW_BASE_URL=
OPENCLAW_SECRET=
OPENCLAW_EMAIL_USER=openclaw@example.com
OPENCLAW_EMAIL_PASSWORD=replace_with_email_app_password
OPENCLAW_SMTP_HOST=smtp.example.com
OPENCLAW_SMTP_PORT=587
OPENCLAW_SMTP_SECURE=false
OPENCLAW_IMAP_HOST=imap.example.com
OPENCLAW_IMAP_PORT=993
OPENCLAW_IMAP_TLS=true
LOCAL_WHISPER_URL=http://127.0.0.1:9000/asr

# ─── Security ─────────────────────────────────────────────────────────
API_INTERNAL_SECRET=your_internal_secret_here
CORS_ORIGINS=
LOCATION_HISTORY_LIMIT=500

# ─── JWT (future auth) ───────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
