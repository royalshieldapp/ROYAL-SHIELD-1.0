# ─── Server ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Scanner (VirusTotal) ─────────────────────────────────────────────
VIRUSTOTAL_API_KEY=your_virustotal_key_here

# ─── AI Assistant (Gemini) ────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── SOS / SMS (Twilio) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── Phone Lookup ─────────────────────────────────────────────────────
DID_API_KEY=your_did_api_key_here
NUMVERIFY_API_KEY=your_numverify_api_key_here

# ─── Billing (Google Play) ───────────────────────────────────────────
# Paste the full JSON content of your Google Play service account
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# ─── VPN (WireGuard) ─────────────────────────────────────────────────
VPN_PROVIDER=
VPN_SERVER_PUBLIC_KEY=
VPN_PORT=51820
VPN_DNS=1.1.1.1, 1.0.0.1
# Format: id:name:host,id:name:host
VPN_SERVERS=

# ─── OpenClaw ─────────────────────────────────────────────────────────
OPENCLAW_BASE_URL=
OPENCLAW_SECRET=

# ─── Security ─────────────────────────────────────────────────────────
API_INTERNAL_SECRET=your_internal_secret_here
CORS_ORIGINS=

# ─── JWT (future auth) ───────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
