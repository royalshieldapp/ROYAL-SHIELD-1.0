<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="com.android.vending.BILLING" />

    <!-- Location permissions for real GPS on SOS button -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Vibration permission for feedback when pressing SOS button -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Permission to access camera -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Permission to send SMS (Critical for Silent SOS) -->
    <uses-permission android:name="android.permission.SEND_SMS" />

    <!-- Permission to record audio -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- SMS Guard Permissions (Phase 2.A) -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />

    <!-- Permission to scan other apps (VirusTotal) -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <!-- Permission to read external files (for scanning) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <!-- Declare that the app uses the camera, but it is not mandatory -->
    <!-- Permission to start foreground services (Critical for Android 9+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- VPN Permission -->
    <uses-permission android:name="android.permission.BIND_VPN_SERVICE" />

    <!-- Notification Permission (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Overlay permission for AI Voice Scam Protection -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application android:name=".RoyalShieldApp" android:allowBackup="true" android:icon="@mipmap/ic_launcher" android:label="@string/app_name" android:roundIcon="@mipmap/ic_launcher_round" android:supportsRtl="true" android:theme="@style/Theme.Royal_shield">

        <!-- Fix for AdServices config conflict between Analytics and Ads -->
        <property android:name="android.adservices.AD_SERVICES_CONFIG" android:resource="@xml/gma_ad_services_config" tools:replace="android:resource" />

        <!-- Background Service -->
        <service android:name=".services.RoyalShieldService" android:enabled="true" android:exported="false" android:foregroundServiceType="location|camera|microphone" />

        <!-- VPN Service -->
        <service android:name=".vpn.RoyalVpnService" android:permission="android.permission.BIND_VPN_SERVICE" android:exported="false">
            <intent-filter>
                <action android:name="android.net.VpnService"/>
            </intent-filter>
        </service>

        <service android:name="com.wireguard.android.backend.GoBackend$VpnService" android:permission="android.permission.BIND_VPN_SERVICE" android:exported="false">
            <intent-filter>
                <action android:name="android.net.VpnService"/>
            </intent-filter>
        </service>

        <!-- Location Tracking Service -->
        <service android:name=".services.LocationTrackerService" android:enabled="true" android:exported="false" android:foregroundServiceType="location" />

        <meta-data android:name="com.google.android.geo.API_KEY" android:value="${MAPS_API_KEY}" />

        <!-- AdMob App ID (Test - Replace with real ID when you get it from AdMob Console) -->
        <!-- Real Advertiser ID: db201234-2403-4297-8158-10ca1ad1abe1 (needs to be registered in AdMob) -->
        <meta-data android:name="com.google.android.gms.ads.APPLICATION_ID" android:value="${ADMOB_APP_ID}"/>


        <!-- Main Activity (LAUNCHER) -->
        <activity android:name=".MainActivity" android:exported="true" android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Registration Activity -->
        <activity android:name=".RegisterActivity" android:exported="false" android:label="Create Account" android:windowSoftInputMode="adjustResize" />

        <!-- Discrete Mode Activity (Stealth) -->
        <activity android:name=".DiscreteModeActivity" android:exported="false" android:screenOrientation="portrait" android:label="Discrete Mode" />

        <!-- Google Login Activity -->
        <activity android:name=".GoogleSignInActivity" android:exported="false" android:label="Login with Google" android:parentActivityName=".MainActivity" />

        <!-- Security Activity -->
        <activity android:name=".SecurityActivity" android:exported="false" android:label="Security Center" android:parentActivityName=".MainActivity" />

        <!-- SOS Event History Activity -->
        <activity android:name=".HistoryActivity" android:exported="false" android:label="SOS History" android:parentActivityName=".MainActivity" />

        <!-- Settings Activity -->
        <activity android:name=".SettingsActivity" android:exported="false" android:label="Settings" android:parentActivityName=".MainActivity" />

        <!-- Advanced Settings Activity -->
        <activity android:name=".AdvancedSettingsActivity" android:exported="false" android:label="Advanced Settings" android:parentActivityName=".SettingsActivity" />

        <!-- Live Location Activity -->
        <activity android:name=".LocationActivity" android:exported="false" android:label="Live Location" android:parentActivityName=".MainActivity" />

        <!-- Cyber Threat Map Activity -->
        <activity android:name=".CyberThreatMapActivity" android:exported="false" android:label="Cyber Threat Map" android:parentActivityName=".SecurityActivity" android:hardwareAccelerated="true" />

        <!-- Privacy Advisor Activity -->
        <activity android:name=".PrivacyAdvisorActivity" android:exported="false" android:label="Privacy Advisor" android:parentActivityName=".MainActivity" />

        <!-- Phone Number Check Activity -->
        <activity android:name=".PhoneNumberCheckActivity" android:exported="false" android:label="Check Number" android:parentActivityName=".MainActivity" />

        <!-- QR Scanner Activity -->
        <activity android:name=".QrScannerActivity" android:exported="false" android:label="Secure QR Scanner" android:parentActivityName=".MainActivity" />



        <!-- File Scan Activity -->
        <activity android:name=".FileScanActivity" android:exported="false" android:label="Scan File" android:parentActivityName=".MainActivity" />



        <!-- Course Activity -->
        <activity android:name=".CourseActivity" android:exported="false" android:label="Cybersecurity Courses" />

        <!-- Fundamental Activity -->
        <activity android:name=".FundamentalActivity" android:exported="false" android:label="Cybersecurity Fundamentals" />

        <!-- Scan Results Activity -->
        <activity android:name=".ScanResultsActivity" android:exported="false" android:label="Scan Results" />

        <!-- AI Voice Protection Activity -->
        <activity android:name=".VoiceScamActivity" android:exported="false" android:label="Voice Protection" android:parentActivityName=".SecurityActivity" />

        <!-- Subscription Activity -->
        <activity android:name=".SubscriptionActivity" android:exported="false" android:label="Upgrade Plan" />


        <!-- AI Voice Scam Protection Service -->
        <service android:name=".services.VoiceScamDetectionService" android:permission="android.permission.BIND_CALL_SCREENING_SERVICE" android:exported="true">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService"/>
            </intent-filter>
        </service>

        <!-- Scam Overlay Service -->
        <service android:name=".services.ScamOverlayService" android:enabled="true" android:exported="false" />

        <!-- SMS Guard Receiver -->
        <receiver android:name=".receivers.SmsReceiver" android:enabled="true" android:exported="true" android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- Device Admin Receiver for Brute Force Detection -->
        <receiver android:name=".receivers.RoyalDeviceAdminReceiver" android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data android:name="android.app.device_admin"
                android:resource="@xml/device_admin_policies" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <!-- FileProvider for sharing PDFs -->
        <provider android:name="androidx.core.content.FileProvider" android:authorities="${applicationId}.fileprovider" android:exported="false" android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
