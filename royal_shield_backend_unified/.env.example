# =============================================================================
# Royal Shield Unified Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# DATABASE
# =============================================================================
# Production on Render must set DATABASE_URL from the managed Postgres
# connectionString. Do not use localhost in production.
DATABASE_URL=

# Local development fallback. If DATABASE_URL is empty and POSTGRES_HOST is
# localhost, the app uses sqlite:///./dev.db.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=royal_shield_risk_db
POSTGRES_USER=royal_shield
POSTGRES_PASSWORD=changeme_secure_password

# =============================================================================
# CRIME DATA SOURCES
# =============================================================================
FBI_CRIME_API_KEY=
MIAMI_DADE_APP_TOKEN=

# =============================================================================
# ENVIRONMENTAL DATA SOURCES
# =============================================================================
NASA_FIRMS_API_KEY=
NOAA_CDO_TOKEN=

# =============================================================================
# OSINT FEEDS
# =============================================================================
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=RoyalShield/2.0
NEWS_API_KEY=
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# =============================================================================
# VECTOR DATABASE
# =============================================================================
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=royal-shield-zones

# =============================================================================
# EMBEDDING & AI SERVICES
# =============================================================================
OPENAI_API_KEY=
USE_LOCAL_EMBEDDINGS=true
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =============================================================================
# VIRUSTOTAL (Ported from Node.js backend)
# =============================================================================
# Register at: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# =============================================================================
# TWILIO SMS (SOS Alerts - Ported from Node.js backend)
# =============================================================================
# Register at: https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# GEMINI AI (Optional)
# =============================================================================
GEMINI_API_KEY=

# =============================================================================
# D-ID (Optional - Avatar service)
# =============================================================================
DID_API_KEY=

# =============================================================================
# API SECURITY
# =============================================================================
API_INTERNAL_SECRET=royal_shield_internal_secret_CHANGE_THIS_IN_PRODUCTION
JWT_SECRET=royal_shield_jwt_secret_CHANGE_THIS_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FILE=logs/royal_shield_backend.log
DATA_COLLECTION_INTERVAL_HOURS=6
MODEL_RETRAIN_INTERVAL_DAYS=7

# Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_TTL_SECONDS=3600

# =============================================================================
# MIAMI-DADE CONFIGURATION
# =============================================================================
BBOX_MIN_LAT=25.1398
BBOX_MIN_LNG=-80.8738
BBOX_MAX_LAT=25.9740
BBOX_MAX_LNG=-80.1194
DEFAULT_H3_RESOLUTION=9

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_CRIME_COLLECTION=true
ENABLE_ENVIRONMENTAL_COLLECTION=false
ENABLE_OSINT_COLLECTION=false
ENABLE_CAMERA_INTEGRATION=false
ENABLE_ML_PREDICTIONS=true
ENABLE_VECTOR_SEARCH=false

# =============================================================================
# VPN / TAILSCALE SECURE NETWORKING
# =============================================================================
# Tailscale auth key (Opcional) para automatizar el ingreso a la red VPN
TAILSCALE_AUTH_KEY=
# IP asignada por Tailscale al servidor (Ej: 100.x.x.x)
# Útil si decides configurar binds de red más allá de localhost
TAILSCALE_BIND_IP=100.x.x.x
